# ============================================================
# AI Web3 Dashboard — Variables de Entorno
# Copia este archivo como .env y completa los valores
# ⚠️  NUNCA subas .env a GitHub
# ============================================================

# --- Blockchain ---
# URL RPC de Sepolia (ej. de Alchemy o Infura)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/TU_API_KEY

# Clave privada de tu wallet de testnet (sin el 0x inicial)
PRIVATE_KEY=tu_clave_privada_aqui

# --- IA ---
# API Key de OpenAI
OPENAI_API_KEY=sk-...

# --- Frontend (Vite expone variables con prefijo VITE_) ---
VITE_CONTRACT_ADDRESS=0x...
VITE_OPENAI_API_KEY=sk-...
VITE_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/TU_API_KEY
